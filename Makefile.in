DESTDIR =
prefix = @prefix@
exec_prefix = @exec_prefix@
bindir = @bindir@
CC = @CC@
CXX = @CXX@

TARGET = recdvb
TARGET2 = recpt1ctl
TARGET3 = chkdvbsignal
TARGET4 = tssplitter_lite
TARGETS = $(TARGET) $(TARGET2) $(TARGET3) $(TARGET4)
RELEASE_VERSION = "1.2.1.1"

CPPFLAGS = -Wall -D_LARGEFILE_SOURCE -D_FILE_OFFSET_BITS=64 @B61_CPPFLAGS@
CFLAGS   = -O2 -g -pthread
CXXFLAGS = -O2 -g -pthread -std=c++20 -Wall @B61_CPPFLAGS@

LIBS     = @LIBS@
LIBS2    = -lm
LIBS3    = -lpthread -lm
LIBS4    =
B61_LIBS = @B61_LIBS@
LDFLAGS  =

B61_OBJS = @B61_OBJS@
REC_OBJS = recpt1.o decoder.o mkpath.o tssplitter_lite.o recpt1core.o
OBJS  = $(REC_OBJS) $(B61_OBJS)
OBJS2 = recpt1ctl.o recpt1core.o
OBJS3 = checksignal.o recpt1core.o
OBJS4 = tssplitter_lite.o tsmain.o
OBJALL = $(OBJS) $(OBJS2) $(OBJS3) $(OBJS4)
DEPEND = .deps

ifdef EXTRA_SID
CPPFLAGS += -DENABLE_EXTRA_SID
endif

all: $(TARGETS)

clean:
	rm -f $(OBJALL) $(TARGETS) $(DEPEND) version.h

distclean: clean
	rm -f Makefile config.h config.log config.status

maintainer-clean: distclean
	rm -fr configure config.h.in aclocal.m4 autom4te.cache *~

$(TARGET): $(OBJS)
	$(CXX) $(LDFLAGS) -o $@ $(OBJS) $(LIBS) $(B61_LIBS)

$(TARGET2): $(OBJS2)
	$(CC) $(LDFLAGS) -o $@ $(OBJS2) $(LIBS2)

$(TARGET3): $(OBJS3)
	$(CC) $(LDFLAGS) -o $@ $(OBJS3) $(LIBS3)

$(TARGET4): $(OBJS4)
	$(CC) $(LDFLAGS) -o $@ $(OBJS4) $(LIBS4)

acas_passthrough.o: acas_passthrough.cpp acas_passthrough.h
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Original source: dantto4k/src/aes.cpp
# Project: https://github.com/nekohkr/dantto4k.git
# Local source revision: 141fd49cf674c9c9e3f3c770a20b3291ff292969
dantto_aes.o: @DANTTO4K_SRC@/aes.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(DEPEND): version.h
	$(CC) -MM $(REC_OBJS:.o=.c) $(OBJS2:.o=.c) $(CPPFLAGS) > $@

version.h:
	revh=`hg parents --template 'const char *version = "r{rev}:{node|short} ({date|shortdate})";\n' 2>/dev/null`; \
	if [ -n "$$revh" ] ; then \
		echo "$$revh" > $@; \
	else \
		echo "const char *version = \"$(RELEASE_VERSION)\";" > $@; \
	fi

install: $(TARGET)
	install -m 755 $(TARGETS) $(DESTDIR)$(bindir)

-include .deps
